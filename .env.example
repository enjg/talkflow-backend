# ===== 应用配置 =====
APP_NAME=ai-spoken-practice
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_spoken

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== MiMo AI =====
MIMO_API_KEY=your-mimo-api-key-here
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_CHAT_MODEL=mimo-v2.5-pro
MIMO_OMNI_MODEL=mimo-v2-omni
MIMO_TTS_MODEL=mimo-v2.5-tts

# ===== JWT =====
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== CORS =====
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ===== 频率限制 =====
RATE_LIMIT_PER_MINUTE=60
